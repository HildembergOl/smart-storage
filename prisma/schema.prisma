generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Enterprise {
  id                BigInt   @id @default(autoincrement())
  publicCode        String   @unique @default(cuid())
  status            String   @default("Ativo")
  enterpriseType    String // "Fisica" | "Juridica"
  legalName         String
  tradeName         String?
  taxId             String   @unique
  stateRegistration String?
  address           String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  notes             String?
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stocks           Stock[]
  sections         Section[]
  positions        Position[]
  products         Product[]
  people           Person[]
  entries          Entry[]
  orders           Order[]
  payments         Payment[]
  receipts         Receipt[]
  userEnterprises  UserEnterprise[]
  invites          UserInvite[]
}

model Stock {
  id           BigInt @id @default(autoincrement())
  publicCode   String @unique @default(cuid())
  description  String
  status       String @default("Ativo")
  enterpriseId BigInt
  tenantId     BigInt?

  enterprise    Enterprise     @relation(fields: [enterpriseId], references: [id])
  tenant        Person?        @relation(fields: [tenantId], references: [id])
  positions     Position[]
  productStocks ProductStock[]
  entries       Entry[]
  orders        Order[]
}

model Section {
  id           BigInt @id @default(autoincrement())
  publicCode   String @unique @default(cuid())
  description  String
  enterpriseId BigInt

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  positions  Position[]
}

model Position {
  id           BigInt  @id @default(autoincrement())
  publicCode   String? @unique @default(cuid())
  stockId      BigInt
  sectionId    BigInt
  aisle        String?
  block        String?
  floor        String?
  location     String?
  enterpriseId BigInt

  enterprise       Enterprise        @relation(fields: [enterpriseId], references: [id])
  stock            Stock             @relation(fields: [stockId], references: [id])
  section          Section           @relation(fields: [sectionId], references: [id])
  productPositions ProductPosition[]
}

model Product {
  id            BigInt @id @default(autoincrement())
  publicCode    String @unique @default(cuid())
  description   String
  
  unitOfMeasureId BigInt?
  brandId         BigInt?
  categoryId      BigInt?
  groupId         BigInt?
  subgroupId      BigInt?

  productType   String // "Produto" | "Servico"
  controlType   String // "Padrao" | "Lote" | "Validade" | "Grade" | "NumeroSerie"
  coverImage    String?
  status        String @default("Ativo")
  enterpriseId  BigInt

  enterprise        Enterprise         @relation(fields: [enterpriseId], references: [id])
  unitOfMeasure     ProductAttribute?  @relation("ProductUnit", fields: [unitOfMeasureId], references: [id])
  brand             ProductAttribute?  @relation("ProductBrand", fields: [brandId], references: [id])
  category          ProductAttribute?  @relation("ProductCategory", fields: [categoryId], references: [id])
  group             ProductAttribute?  @relation("ProductGroup", fields: [groupId], references: [id])
  subgroup          ProductAttribute?  @relation("ProductSubgroup", fields: [subgroupId], references: [id])
  
  packages          Package[]
  productStocks     ProductStock[]
  productPositions  ProductPosition[]
  entryItems        EntryItem[]
  orderItems        OrderItem[]
  marketplaceImages MarketplaceImage[]
}

model Package {
  id              BigInt  @id @default(autoincrement())
  status          String  @default("Ativo")
  unitOfMeasureId BigInt?
  barcode         String?
  factor          Float   @default(1)
  height          Float?
  width           Float?
  length          Float?
  cubage          Float?
  grossWeight     Float?
  netWeight       Float?
  productId       BigInt

  product       Product           @relation(fields: [productId], references: [id])
  unitOfMeasure ProductAttribute? @relation("PackageUnit", fields: [unitOfMeasureId], references: [id])
}

model ProductStock {
  id        BigInt  @id @default(autoincrement())
  productId BigInt
  stockId   BigInt
  costPrice Float   @default(0)
  active    Boolean @default(true)
  quantity  Float   @default(0)

  product Product @relation(fields: [productId], references: [id])
  stock   Stock   @relation(fields: [stockId], references: [id])
}

model ProductPosition {
  id           BigInt    @id @default(autoincrement())
  productId    BigInt
  positionId   BigInt
  quantity     Float     @default(0)
  batch        String?
  expiry       DateTime?
  grid         String?
  serialNumber String?

  product  Product  @relation(fields: [productId], references: [id])
  position Position @relation(fields: [positionId], references: [id])
}

model MarketplaceImage {
  id        BigInt @id @default(autoincrement())
  productId BigInt
  url       String
  stockId   BigInt?

  product Product @relation(fields: [productId], references: [id])
}

model Person {
  id                BigInt  @id @default(autoincrement())
  publicCode        String? @unique @default(cuid())
  personType        String // "Fisica" | "Juridica"
  legalName         String
  tradeName         String?
  taxId             String
  stateRegistration String?
  address           String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  notes             String?
  email             String?
  isClient          Boolean @default(false)
  isSupplier        Boolean @default(false)
  isEmployee        Boolean @default(false)
  isTenant          Boolean @default(false)
  isVehicle         Boolean @default(false)
  enterpriseId      BigInt

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  stocks     Stock[]
  entries    Entry[]
  orders     Order[]
  payments   Payment[]
  receipts   Receipt[]
  tenants    UserTenant[]
}

model Entry {
  id           BigInt   @id @default(autoincrement())
  publicCode   String?  @unique @default(cuid())
  stockId      BigInt
  personId     BigInt
  number       String
  type         String // "NF-e" | "CF-e" | "Manual"
  nfeKey       String?
  totalProduct Float    @default(0)
  totalNfe     Float    @default(0)
  notes        String?
  enterpriseId BigInt
  createdAt    DateTime @default(now())

  enterprise  Enterprise        @relation(fields: [enterpriseId], references: [id])
  stock       Stock             @relation(fields: [stockId], references: [id])
  person      Person            @relation(fields: [personId], references: [id])
  items       EntryItem[]
  invoices    EntryInvoice[]
  attachments EntryAttachment[]
}

model EntryItem {
  id        BigInt @id @default(autoincrement())
  entryId   BigInt
  productId BigInt
  quantity  Float
  unitValue Float

  entry   Entry   @relation(fields: [entryId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model EntryInvoice {
  id            BigInt   @id @default(autoincrement())
  entryId       BigInt
  paymentMethod String
  number        String
  dueDate       DateTime
  value         Float

  entry Entry @relation(fields: [entryId], references: [id])
}

model EntryAttachment {
  id          BigInt  @id @default(autoincrement())
  entryId     BigInt
  url         String
  description String?

  entry Entry @relation(fields: [entryId], references: [id])
}

model Order {
  id           BigInt   @id @default(autoincrement())
  publicCode   String?  @unique @default(cuid())
  stockId      BigInt
  personId     BigInt
  number       String
  type         String
  nfeKey       String?
  totalProduct Float    @default(0)
  totalNfe     Float    @default(0)
  notes        String?
  enterpriseId BigInt
  createdAt    DateTime @default(now())

  enterprise Enterprise  @relation(fields: [enterpriseId], references: [id])
  stock      Stock       @relation(fields: [stockId], references: [id])
  person     Person      @relation(fields: [personId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id        BigInt @id @default(autoincrement())
  orderId   BigInt
  productId BigInt
  quantity  Float
  unitValue Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id            BigInt   @id @default(autoincrement())
  number        String
  personId      BigInt
  dueDate       DateTime
  paymentMethod String
  value         Float
  balance       Float
  status        String   @default("EmAberto") // "EmAberto" | "Pago" | "Vencido"
  enterpriseId  BigInt
  createdAt     DateTime @default(now())

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  person     Person     @relation(fields: [personId], references: [id])
}

model Receipt {
  id            BigInt   @id @default(autoincrement())
  number        String
  personId      BigInt
  dueDate       DateTime
  paymentMethod String
  value         Float
  balance       Float
  status        String   @default("EmAberto") // "EmAberto" | "Recebido" | "Vencido"
  enterpriseId  BigInt
  createdAt     DateTime @default(now())

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  person     Person     @relation(fields: [personId], references: [id])
}

model User {
  id        BigInt  @id @default(autoincrement())
  email     String  @unique
  publicKey String  @unique
  name      String?
  phone     String?
  jobTitle  String?
  avatarUrl String?

  enterprises UserEnterprise[]
  tenant      UserTenant?
  invites     UserInvite[]
}

model UserEnterprise {
  id           BigInt @id @default(autoincrement())
  userId       BigInt
  enterpriseId BigInt

  user       User       @relation(fields: [userId], references: [id])
  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  @@unique([userId, enterpriseId])
}

model UserTenant {
  id       BigInt @id @default(autoincrement())
  userId   BigInt @unique
  tenantId BigInt

  user   User   @relation(fields: [userId], references: [id])
  tenant Person @relation(fields: [tenantId], references: [id])
}

model UserInvite {
  id           BigInt   @id @default(autoincrement())
  email        String
  enterpriseId BigInt
  role         String   @default("Usuario")
  status       String   @default("Pendente")
  createdAt    DateTime @default(now())
  invitedById  BigInt

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  invitedBy  User       @relation(fields: [invitedById], references: [id])
}

model ProductAttribute {
  id         BigInt   @id @default(autoincrement())
  publicCode String   @unique @default(cuid())
  name       String   @unique
  type       String   // "unidade_medida" | "marca" | "categoria" | "grupo" | "subgrupo"
  status     String   @default("Ativo")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  unitProducts     Product[] @relation("ProductUnit")
  brandProducts    Product[] @relation("ProductBrand")
  categoryProducts Product[] @relation("ProductCategory")
  groupProducts    Product[] @relation("ProductGroup")
  subgroupProducts Product[] @relation("ProductSubgroup")
  packageUnits     Package[] @relation("PackageUnit")
}
